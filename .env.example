# ImgBed 环境变量配置示例
# 复制此文件为 .env 并修改相应的值

# 服务器端口（默认 3000）
PORT=3000

# JWT 密钥（用于用户认证）
# ⚠️ 生产环境请务必修改为强密码（至少32个随机字符）
# 示例: JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_SECRET=your-secret-key-change-this-in-production

# 运行环境
# 开发环境: development
# 生产环境: production
NODE_ENV=development

# API 密钥（可选，用于 API 上传接口）
# ⚠️ 如果需要使用 API 上传功能，请设置此项
# ⚠️ 建议使用强密码（至少32个随机字符）
# 示例: API_KEY=ImgB3dSecUr3Key2024#Pr0ducti0n
# 注意: 也可以在启动后通过设置页面修改 API Key（修改后立即生效无需重启）
# 注意: 设置页面修改的 API Key 优先级高于此环境变量
# API_KEY=

# 数据库文件路径（可选，默认为 data/imgbed.db）
# DB_PATH=data/imgbed.db

# ========== 可选配置 ==========

# CORS 配置（可选，默认允许所有来源）
# CORS_ORIGIN=*

# 请求体大小限制（可选，单位：字节）
# 设置为 0 或不设置表示不限制（默认）
# 注意：各平台有独立的大小限制：Discord 25MB、Telegram 50MB、HuggingFace 和 Local Drive 不限制
# MAX_FILE_SIZE=0

# 日志级别（可选）
# LOG_LEVEL=info

# Local Drive 默认服务器地址（可选，也可在设置页面配置）
# LOCAL_DRIVE_SERVER_URL=http://your-server:port
